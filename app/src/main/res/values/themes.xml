<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- White background during launch (pre-Android 12 launch window). -->
        <item name="android:windowBackground">@android:color/white</item>
        <!-- White splash background on Android 12+. -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@android:color/white</item>
    </style>

    <style name="Theme.PdfEditorSpike" parent="Theme.Material3.DayNight.NoActionBar" />

    <style name="BarBtn" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:textColor">#111827</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ToolBtn" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
